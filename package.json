{
  "name": "ynab-mcp-bridge",
  "version": "0.14.2",
  "description": "ynab-mcp-bridge MCP server",
  "author": "Matt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mossipcams/ynab-mcp-bridge.git"
  },
  "homepage": "https://github.com/mossipcams/ynab-mcp-bridge#readme",
  "bugs": {
    "url": "https://github.com/mossipcams/ynab-mcp-bridge/issues"
  },
  "type": "module",
  "bin": {
    "ynab-mcp-bridge": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && node --max-old-space-size=6144 ./node_modules/typescript/bin/tsc && chmod +x dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "lint:deps": "dependency-cruiser --config .dependency-cruiser.js src",
    "lint:unused": "knip --config knip.json --production --exclude dependencies",
    "typecheck": "node --max-old-space-size=6144 ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json && node --max-old-space-size=6144 ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.test.json",
    "prepare": "npm run build",
    "watch": "node --max-old-space-size=6144 ./node_modules/typescript/bin/tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "start:stdio": "node dist/index.js --transport stdio",
    "debug": "npm run build && npx @modelcontextprotocol/inspector dist/index.js",
    "test": "vitest",
    "test:ci": "mkdir -p artifacts/test-results && vitest run --reporter=default --reporter=junit --outputFile.junit=./artifacts/test-results/vitest-junit.xml",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "preflight": "npm run test:ci && npm run test:coverage && npm run lint:deps && npm run lint && npm run typecheck && npm run lint:unused && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "jose": "^6.2.1",
    "pino": "^10.3.1",
    "ynab": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@modelcontextprotocol/inspector": "^0.16.5",
    "@types/express": "^5.0.5",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "knip": "^5.88.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
